APP_NAME=MedVision Backend
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql+psycopg://medvision:medvision@postgres:5432/medvision
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_DOMAIN=
COOKIE_SECURE=false
MILESTONE_ENV=development

# ── Vector DB ─────────────────────────────────────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=document_chunks

# MinIO in docker-compose is used by Milvus object storage internally.
# User document uploads are stored on the local filesystem under STORAGE_ROOT (see storage.py), not via the MinIO API.

# ── Embeddings (read by Settings in app/core/config.py) ─────────────────────────
# BioBERT is loaded directly with `transformers` (AutoTokenizer + AutoModel) and
# uses attention-mask-aware mean pooling + L2 normalisation. Falls back to a
# deterministic hash embedder if torch / transformers are missing.
# EMBEDDING_DIMENSIONS must match the model (BioBERT → 768; hash fallback → 256).
BIOBERT_MODEL_NAME=dmis-lab/biobert-v1.1
# Optional: local directory with a downloaded model (air-gapped installs)
BIOBERT_LOCAL_PATH=
EMBEDDING_DIMENSIONS=768

# ── Reranker (aliases: retrieval_enable_reranker, cross_encoder_model) ─────────
RERANKER_ENABLED=true
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=50

# ── OCR (ENABLE_* / ALLOW_* map to Settings; model id is not configurable via Settings yet) ──
# Suppress the PaddleOCR model-hoster connectivity check on every ingestion (already set in Dockerfile)
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
ENABLE_PADDLEOCR_VL=true
PADDLEOCR_VL_USE_DOC_ORIENTATION_CLASSIFY=false
PADDLEOCR_VL_USE_DOC_UNWARPING=false
ALLOW_OCR_FALLBACK=true
ENABLE_DICOM_ANONYMIZATION=true

# ── Bootstrap admin account ────────────────────────────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@medvision.ai
BOOTSTRAP_ADMIN_PASSWORD=Admin123!
BOOTSTRAP_ADMIN_FULL_NAME=MedVision Admin
BOOTSTRAP_ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP

# ── Admin allowlist (HARD CAP: only these emails can hold the admin role) ─────
# Comma-separated list of up to 3 admin emails. The bootstrap admin is always
# implicitly included. Any DB row whose email is NOT in this list is demoted to
# student on the next app start. Login as admin is rejected for non-allowlisted
# emails even if the DB role says admin.
ADMIN_ALLOWED_EMAILS=admin@medvision.ai,admin2@medvision.ai,admin3@medvision.ai

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Provider: openai | ollama | none
# "openai"  — uses GPT-4o-mini for chat, GPT-4o for vision (needs API key)
# "ollama"  — uses local Ollama models (needs ollama serve + pulled models)
ASSISTANT_LLM_PROVIDER=openai
ASSISTANT_ENABLE_VERIFIER=true

# ── OpenAI API (active when ASSISTANT_LLM_PROVIDER=openai) ───────────────────
ASSISTANT_OPENAI_API_KEY=sk-your-key-here
ASSISTANT_OPENAI_BASE_URL=https://api.openai.com/v1
ASSISTANT_OPENAI_MODEL=gpt-4o-mini
ASSISTANT_OPENAI_MAX_TOKENS=1024
OPENAI_VISION_MODEL=gpt-4o

# Run `ollama serve` then pull a chat + vision model.
# For systems with >=16 GB RAM:
#   ollama pull llama3.1:8b-instruct-q4_K_M
#   ollama pull qwen2.5vl:7b-q4_K_M
# For low-RAM systems (<8 GB free):
#   ollama pull llama3.2:3b
#   ollama pull llava:7b      (or skip vision features)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_REQUEST_TIMEOUT_S=180
OLLAMA_CHAT_MAX_TOKENS=1024
OLLAMA_TEMPERATURE=0.2
# Context window cap — Llama 3.2 defaults to 128k which needs ~13 GB KV cache.
# 4096 is sufficient for RAG; raise to 8192 if you have more RAM.
OLLAMA_NUM_CTX=4096

# region disabled-cloud-providers (Gemini — not currently used)
ASSISTANT_GEMINI_API_KEY=
ASSISTANT_GEMINI_MODEL=gemini-2.5-flash-lite
# endregion disabled-cloud-providers

# ── Vision / Explainability ───────────────────────────────────────────────────
# Provider: openai | ollama. Uses ASSISTANT_OPENAI_API_KEY when set to openai.
VISION_PROVIDER=openai

# region disabled-vision-cloud-providers
VISION_GEMINI_API_KEY=
VISION_GEMINI_MODEL=gemini-2.5-flash-lite
VISION_QWEN_BASE_URL=
VISION_QWEN_API_KEY=
VISION_QWEN_MODEL=qwen2.5-vl
# endregion disabled-vision-cloud-providers

# ── ML / Explainability feature gate ─────────────────────────────────────────
# Set to true to enable GradCAM++, LIME, SHAP (requires torch installed)
ML_FEATURES_ENABLED=true
# Path to optional CheXNet weights for true GradCAM++ (leave blank to use ImageNet weights)
CHEXNET_WEIGHTS_PATH=
