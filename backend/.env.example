APP_NAME=MedVision Backend
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql+psycopg://medvision:medvision@postgres:5432/medvision
JWT_SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_DOMAIN=
COOKIE_SECURE=false
MILESTONE_ENV=development
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=document_chunks
EMBEDDING_DIMENSIONS=256
STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=50
ENABLE_PADDLEOCR_VL=true
PADDLEOCR_VL_MODEL_NAME=PaddlePaddle/PaddleOCR-VL-1.5
PADDLEOCR_VL_USE_DOC_ORIENTATION_CLASSIFY=false
PADDLEOCR_VL_USE_DOC_UNWARPING=false
ALLOW_OCR_FALLBACK=true
ENABLE_DICOM_ANONYMIZATION=true
BOOTSTRAP_ADMIN_EMAIL=admin@medvision.ai
BOOTSTRAP_ADMIN_PASSWORD=Admin123!
BOOTSTRAP_ADMIN_FULL_NAME=MedVision Admin
BOOTSTRAP_ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP

# Module 3: Grounded Assistant (optional LLM synthesis)
ASSISTANT_LLM_PROVIDER=none  # none | openai | gemini
ASSISTANT_OPENAI_API_KEY=
ASSISTANT_OPENAI_BASE_URL=https://api.openai.com/v1
ASSISTANT_OPENAI_MODEL=gpt-4o-mini
ASSISTANT_ENABLE_VERIFIER=false

# Module 3: Medical-domain chatbot mode (Gemini)
ASSISTANT_GEMINI_API_KEY=
ASSISTANT_GEMINI_MODEL=gemini-2.5-flash-lite

# Phase 4: Vision (caption/VQA)
VISION_PROVIDER=gemini
VISION_GEMINI_API_KEY=
VISION_GEMINI_MODEL=gemini-2.5-flash-lite

# Phase 4: Qwen2.5-VL (preferred) via OpenAI-compatible endpoint (vLLM/etc.)
VISION_QWEN_BASE_URL=
VISION_QWEN_API_KEY=
VISION_QWEN_MODEL=qwen2.5-vl
